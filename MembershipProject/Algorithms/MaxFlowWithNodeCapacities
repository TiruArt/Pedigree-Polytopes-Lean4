def test_node_capacity_bottleneck():
    """
    Test where node capacity is the bottleneck
    Source -> Mid1 -> Sink
          -> Mid2 -> 
    Both paths available but middle nodes have limited capacity
    """
    net = LayeredFlowNetwork()
    
    source = (1, 2, 3)
    mid1 = (1, 3, 4)
    mid2 = (2, 3, 4)
    sink = (2, 4, 5)
    
    net.add_node(source, Fraction(1), 0)
    net.add_node(mid1, Fraction(1, 4), 1)  # Node bottleneck
    net.add_node(mid2, Fraction(1, 4), 1)  # Node bottleneck
    net.add_node(sink, Fraction(1), 2)
    
    # All edges have capacity 1
    net.add_edge(source, mid1, Fraction(1))
    net.add_edge(source, mid2, Fraction(1))
    net.add_edge(mid1, sink, Fraction(1))
    net.add_edge(mid2, sink, Fraction(1))
    
    max_flow = net.max_flow(source, sink)
    
    print("Test 5 - Node capacity bottleneck:")
    print(f"  Max-flow: {max_flow}")
    print(f"  Expected: 1/2 (sum of mid node capacities: 1/4 + 1/4)")
    print(f"  Passed: {max_flow == Fraction(1, 2)}\n")


def test_complex_layered_network():
    """
    More complex network with 5 layers
    Tests multiple bottlenecks and path interactions
    """
    net = LayeredFlowNetwork()
    
    # Layer 0
    s = (1, 2, 3)
    net.add_node(s, Fraction(1), 0)
    
    # Layer 1
    a = (1, 3, 4)
    b = (2, 3, 4)
    net.add_node(a, Fraction(1, 3), 1)
    net.add_node(b, Fraction(2, 3), 1)
    
    # Layer 2
    c = (2, 4, 5)
    d = (3, 4, 5)
    net.add_node(c, Fraction(1, 4), 2)
    net.add_node(d, Fraction(1, 2), 2)
    
    # Layer 3
    e = (3, 5, 6)
    net.add_node(e, Fraction(1, 3), 3)
    
    # Layer 4 (sink)
    t = (4, 5, 7)
    net.add_node(t, Fraction(1), 4)
    
    # Edges layer 0 -> 1
    net.add_edge(s, a, Fraction(1))
    net.add_edge(s, b, Fraction(1))
    
    # Edges layer 1 -> 2
    net.add_edge(a, c, Fraction(1))
    net.add_edge(a, d, Fraction(1))
    net.add_edge(b, c, Fraction(1))
    net.add_edge(b, d, Fraction(1))
    
    # Edges layer 2 -> 3
    net.add_edge(c, e, Fraction(1))
    net.add_edge(d, e, Fraction(1))
    
    # Edges layer 3 -> 4
    net.add_edge(e, t, Fraction(1))
    
    max_flow = net.max_flow(s, t)
    
    print("Test 6 - Complex layered network:")
    print(f"  Max-flow: {max_flow}")
    print(f"  Expected: 1/3 (bottleneck at node e with capacity 1/3)")
    print(f"  Passed: {max_flow == Fraction(1, 3)}\n")


def test_multiple_paths_different_capacities():
    """
    Test network with multiple paths having different capacities
    """
    net = LayeredFlowNetwork()
    
    source = (1, 2, 3)
    mid1 = (1, 3, 4)
    mid2 = (2, 3, 4)
    mid3 = (1, 4, 5)
    sink = (2, 5, 6)
    
    net.add_node(source, Fraction(1), 0)
    net.add_node(mid1, Fraction(1, 5), 1)
    net.add_node(mid2, Fraction(2, 5), 1)
    net.add_node(mid3, Fraction(1, 10), 2)
    net.add_node(sink, Fraction(1), 3)
    
    # Path 1: source -> mid1 -> mid3 -> sink
    net.add_edge(source, mid1, Fraction(1, 4))
    net.add_edge(mid1, mid3, Fraction(1))
    
    # Path 2: source -> mid2 -> mid3 -> sink
    net.add_edge(source, mid2, Fraction(1))
    net.add_edge(mid2, mid3, Fraction(1))
    
    # Final edge
    net.add_edge(mid3, sink, Fraction(1))
    
    max_flow = net.max_flow(source, sink)
    
    print("Test 7 - Multiple paths with different capacities:")
    print(f"  Max-flow: {max_flow}")
    print(f"  Expected: 1/10 (bottleneck at mid3 with capacity 1/10)")
    print(f"  Passed: {max_flow == Fraction(1, 10)}\n")


def test_diamond_network():
    """
    Diamond-shaped network
         -> mid1 ->
    source          sink
         -> mid2 ->
    """
    net = LayeredFlowNetwork()
    
    source = (1, 2, 3)
    mid1 = (1, 3, 4)
    mid2 = (2, 3, 4)
    sink = (2, 4, 5)
    
    net.add_node(source, Fraction(1), 0)
    net.add_node(mid1, Fraction(1, 3), 1)
    net.add_node(mid2, Fraction(2, 3), 1)
    net.add_node(sink, Fraction(1), 2)
    
    net.add_edge(source, mid1, Fraction(1, 2))
    net.add_edge(source, mid2, Fraction(1, 2))
    net.add_edge(mid1, sink, Fraction(1))
    net.add_edge(mid2, sink, Fraction(1))
    
    max_flow = net.max_flow(source, sink)
    
    print("Test 8 - Diamond network:")
    print(f"  Max-flow: {max_flow}")
    # Path through mid1: min(1/2, 1/3, 1) = 1/3
    # Path through mid2: min(1/2, 2/3, 1) = 1/2
    # But source only has capacity 1, and edges from source sum to 1
    # Actually: flow through mid1 limited by min(1/2 edge, 1/3 node) = 1/3
    #           flow through mid2 limited by min(1/2 edge, 2/3 node) = 1/2
    # Total: 1/3 + 1/2 = 5/6, but source edges limit to 1/2 + 1/2 = 1
    # So should be min(5/6, 1) = 5/6
    expected = Fraction(5, 6)
    print(f"  Expected: {expected}")
    print(f"  Passed: {max_flow == expected}\n")


