axiom MCF_feasible (k : ℕ) {n : ℕ} (X : ParsedMIRData n) : Prop
axiom convex_hull_has_decomposition {n : ℕ} (X : ParsedMIRData n)
  (h : X ∈ conv(Pedigrees_n)) :
  ∃ decomp : ConvexDecomposition n X, True
axiom stage_flow_feasible (k : ℕ) {n : ℕ} (X : ParsedMIRData n)
  (decomp : ConvexDecomposition n X) (flow : Node → Node → Rat) : Prop
axiom conv {α : Type*} (S : Set α) : Set α

-- ============================================================================
-- KEY LEMMA: Partition Properties from Pedigree Structure
-- ============================================================================

/--
Pedigrees naturally partition via edges at each layer.

**Why this is true:**
- Each pedigree is a path (1,2,3) → ... → (i,j,k) → ... → (_,_,n)
- At layer k, each pedigree uses exactly one edge
- Therefore edges at layer k partition the set of pedigrees
-/
lemma pedigrees_partition_by_layer_edges {n k : ℕ}
  (decomp : List (WeightedPedigree n))
  (edges_k : Finset Node)
  (h_complete : ∀ wp ∈ decomp, ∃ e ∈ edges_k,
    wp.path.passes_through e at layer k) :
  -- S_O forms a partition
  (∀ e₁ e₂ ∈ edges_k, e₁ ≠ e₂ →
    Disjoint (pedigrees_using_edge_at_layer k e₁ decomp)
             (pedigrees_using_edge_at_layer k e₂ decomp)) ∧
  (∀ i : Fin decomp.length, ∃ e ∈ edges_k,
    i ∈ pedigrees_using_edge_at_layer k e decomp) := by
  constructor
  · -- Disjointness: a pedigree can't use two different edges at same layer
    intro e₁ he₁ e₂ he₂ hne
    rw [Finset.disjoint_iff_ne]
    intro i hi₁ j hj₂
    -- Pedigree i uses e₁, pedigree j uses e₂
    -- If i = j, then pedigree uses both e₁ and e₂ at layer k
    -- But this is impossible (path property)
    sorry
  · -- Coverage: every pedigree uses some edge
    intro i
    exact h_complete (decomp[i]) sorry

